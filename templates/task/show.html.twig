{% extends 'base.html.twig' %}
{% block title %}D&eacute;tail de la t&acirc;che{% endblock %}
{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <h1 class="mb-4">{{ task.title }}</h1>
            <p><strong>Statut :</strong> {{ task.status }}</p>
            <p><strong>Description :</strong> {{ task.description ?: '-' }}</p>
            <p><strong>Date limite :</strong> {{ task.dueDate ? task.dueDate|date('d/m/Y H:i') : '-' }}</p>
            <p><strong>Cr&eacute;&eacute;e le :</strong> {{ task.createdAt|date('d/m/Y H:i') }}</p>
            <p><strong>Cr&eacute;&eacute;e par :</strong> {{ task.createdBy.email }}</p>
            <a href="{{ path('app_task_edit', {id: task.id}) }}" class="btn btn-primary">Modifier</a>
            <a href="{{ path('app_task_index') }}" class="btn btn-link">&larr; Retour &agrave; la liste</a>
        </div>
    </div>
</div>
{% endblock %}